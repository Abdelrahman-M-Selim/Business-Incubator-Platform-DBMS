<header class="py-4 shadow-md bg-brand-slate text-white border-b-4 border-black" x-data="{ open: false }">
  <div class="container mx-auto flex flex-col md:flex-row justify-between items-center px-4 gap-4 md:gap-0 overflow-auto whitespace-nowrap">
    
    <div class="flex w-full justify-between items-center whitespace-nowrap">
      <div class="flex items-center gap-2 sm:gap-3">
        <a href="/" rel="noopener noreferrer" class="hover:-translate-y-1 transition-transform">
          <img
            src="/assets/images/logo.jpg"
            alt="Business Incubator Platform logo"
            class="h-8 w-8 sm:h-9 sm:w-9 md:h-10 md:w-10 rounded-full object-cover border-2 border-white shadow-neo-sm bg-black"
            loading="eager"
            decoding="async"
          />
        </a>
        <a href="/" class="text-base xs:text-lg sm:text-xl md:text-2xl font-black font-display uppercase tracking-tight text-center md:text-left whitespace-nowrap leading-tight hover:text-brand-amber transition-colors">
          Incubator Platform
        </a>
      </div>

      <button
        class="md:hidden flex items-center px-3 py-2 border-2 border-transparent hover:border-white transition-all"
        @click="open = !open"
        aria-label="Toggle menu"
      >
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div
      :class="open ? 'flex' : 'hidden'"
      class="flex-col w-full mt-4 md:mt-0 md:flex md:flex-row md:items-center md:justify-center md:w-auto md:gap-0 gap-4 whitespace-nowrap"
    >
      <nav class="w-full md:w-auto flex flex-col md:flex-row flex-1 md:justify-center items-center md:items-center gap-4 md:gap-0 whitespace-nowrap">
        <ul class="flex flex-col md:flex-row w-full md:w-auto items-center md:space-x-8 space-y-2 md:space-y-0 whitespace-nowrap font-bold font-sans">
          <li>
            <a href="/v1/projects" class="hover:text-brand-amber hover:underline decoration-2 underline-offset-4 transition-all whitespace-nowrap" @click="open = false">
              Projects & Ideas
            </a>
          </li>
          <li>
            <a href="/v1/mentors" class="hover:text-brand-amber hover:underline decoration-2 underline-offset-4 transition-all whitespace-nowrap" @click="open = false">
              Mentors
            </a>
          </li>
          <li>
            <a href="/v1/workshop" class="hover:text-brand-amber hover:underline decoration-2 underline-offset-4 transition-all whitespace-nowrap" @click="open = false">
              Workshops
            </a>
          </li>
          <li>
            <a href="/v1/about" class="text-white px-5 py-2 border-2 border-black hover:bg-brand-amber hover:-translate-y-1 shadow-neo-sm transition-all whitespace-nowrap" @click="open = false">
              About
            </a>
          </li>
        </ul>
      </nav>
      
      <% if (!user) { %>
        <div class="flex flex-col md:flex-row items-center gap-3 w-full md:w-auto justify-center md:justify-end mt-4 md:mt-0 whitespace-nowrap font-bold font-sans">
          <a href="/v1/auth/login" class="px-4 py-2 hover:text-brand-amber hover:underline decoration-2 underline-offset-4 transition-all whitespace-nowrap" @click="open = false">
            Log in
          </a>
          <a href="/v1/auth/signup" class="bg-brand-indigo text-white px-6 py-2 border-2 border-black shadow-neo-sm hover:shadow-none hover:translate-y-1 hover:translate-x-1 font-black uppercase tracking-wider text-center w-full md:w-auto transition-all" @click="open = false">
            Sign up
          </a>
        </div>
      <% } else { %>
        <div class="flex flex-col md:flex-row items-center gap-3 w-full md:w-auto justify-center md:justify-end mt-4 md:mt-0 whitespace-nowrap font-bold font-sans">
          <a href="/v1/auth/profile" class="px-4 py-2 hover:text-brand-amber hover:underline decoration-2 underline-offset-4 transition-all whitespace-nowrap" @click="open = false">
            Profile
          </a>
          <button
            @click="handleLogout()"
            class="bg-red-600 text-white px-6 py-2 border-2 border-black shadow-neo-sm hover:shadow-none hover:translate-x-1 font-black uppercase tracking-wider text-center w-full md:w-auto transition-all cursor-pointer"
          >
            Logout
          </button>
        </div>
      <% } %>
    </div>
  </div>
  
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
  
  <style>
    [x-cloak] { display: none !important; }
  </style>
  
  <script>
    async function handleLogout() {
      if (!confirm('Are you sure you want to logout?')) return;

      try {
        const response = await fetch('/v1/auth/logout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include'
        });

        if (response.ok) {
          localStorage.removeItem('isLoggedIn'); 
          window.location.href = '/v1/auth/login';
        } else {
          alert('Failed to logout. Please try again.');
        }
      } catch (error) {
        console.error('Logout error:', error);
        alert('An error occurred during logout.');
      }
    }
  </script>
</header>